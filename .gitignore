# Per-machine local overrides (never shared)
claude/settings.local.json

# Runtime / ephemeral
codex/tmp/
**/cluster-hooks.log
**/.DS_Store

# Agent memory is LOCAL-ONLY — never pushed (user directive).
# Every role + _shared memory dir is ignored; only the memory/README.md
# (documentation about the memory system) stays tracked.
.agents/memory/*/

# Personal local debug config (absolute paths, per-machine)
claude/launch.json

# Ephemeral agent worktrees + local pre-PR report (never shared)
claude/worktrees/
codex/pre-pr-report.json
